{
  "mcp-atlassian": {
    "command": "uvx",
    "args": [
      "mcp-atlassian"
    ],
    "env": {
      "JIRA_URL": "${JIRA_URL}",
      "JIRA_PERSONAL_TOKEN": "${JIRA_PERSONAL_TOKEN}",
      "CONFLUENCE_URL": "${CONFLUENCE_URL}",
      "CONFLUENCE_PERSONAL_TOKEN": "${CONFLUENCE_PERSONAL_TOKEN}",
      "JIRA_SSL_VERIFY": "true",
      "CONFLUENCE_SSL_VERIFY": "true"
    },
    "disabled": false
  }
}
